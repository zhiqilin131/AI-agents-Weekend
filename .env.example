# Copy this file to `.env` in the same folder and fill in secrets (`.env` is gitignored).
# Tavily — https://docs.tavily.com/
TAVILY_API_KEY= 

# Tavily search depth (advanced, basic, etc.)
TAVILY_SEARCH_DEPTH=advanced

# When true, call Tavily on every run (if TAVILY_API_KEY is set). Otherwise Tavily runs when
# the raw vector hit list has fewer than TAVILY_MIN_CACHE_HITS chunks OR the decision looks time-sensitive.
# For hackathons / demos, set TAVILY_ALWAYS=true so web search always supplements the local cache.
TAVILY_ALWAYS=false
TAVILY_MIN_CACHE_HITS=3

# Chroma persistent store (vector indices)
CHROMA_PERSIST_DIR=./data/chroma

# App data (traces, outcomes, exports)
FORESIGHT_DATA_DIR=./data
FORESIGHT_USER_ID=demo_user

# LLM + embeddings via OpenAI API (used through LlamaIndex wrappers)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: Azure OpenAI or proxy (leave unset for api.openai.com)
# OPENAI_API_BASE=https://your-resource.openai.azure.com
